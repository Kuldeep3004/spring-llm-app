name: CI/CD Pipeline

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
      
      - name: Build
        run: |
          cd backend-java
          mvn clean compile
      
      - name: Test
        run: |
          cd backend-java
          mvn test
      
      - name: AI Review Comment
        if: github.event_name == 'pull_request'
        run: |
          gh pr comment ${{ github.event.pull_request.number }} --body "🤖 AI Code Review: Build successful!"
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}